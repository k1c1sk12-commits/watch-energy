# Public canonical URL of the site — used for metadata, Open Graph and share links.
# On Vercel, set this to your production domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://watch-energy.vercel.app

# Google Analytics 4 Measurement ID (looks like G-XXXXXXXXXX). Leave unset to
# disable analytics (e.g. local dev). Set it in Vercel → Settings → Env Vars.
NEXT_PUBLIC_GA_ID=

# Behold.so Instagram feed URL (https://feeds.behold.so/XXXXXXXX) powering the
# recent-posts thumbnails on the result page. Unset -> the preview is hidden.
NEXT_PUBLIC_BEHOLD_FEED=
